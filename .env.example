# Partoo Dashboard Configuration

# Flask port (default: 5000)
PORT=5000

# Flask environment (production/development)
FLASK_ENV=production

# Optional: preload Partoo API keys locally for testing.
# Copy this file to .env, then fill real keys there. .env is gitignored.
#
# Option A: one JSON object
PARTOO_API_KEYS={"DK":"paste_dk_x_apikey_here","FR":"paste_fr_x_apikey_here"}
#
# Option B: one variable per market. These are merged with PARTOO_API_KEYS.
# PARTOO_API_KEY_DK=paste_dk_x_apikey_here
# PARTOO_API_KEY_FR=paste_fr_x_apikey_here
# PARTOO_API_KEY_UK=paste_uk_x_apikey_here

# Optional: only needed for the Ask the Data chat feature
# OPENAI_API_KEY=paste_openai_key_here
